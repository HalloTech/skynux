<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Freelance Opportunities</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.3/css/all.min.css"
    />
    <style>
      /* Hide scrollbar but keep scrolling */
      .scroll-hide::-webkit-scrollbar {
        display: none;
      }
      .scroll-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>
  </head>
  <body class="bg-white text-gray-900">
    <div class="max-w-7xl mx-auto p-5 pt-20 max-sm:pt-12">
      <!-- Hero Section -->
      <div class="bg-gray-200 rounded-[2rem] mt-10 p-8 text-left">
        <h1 class="text-3xl md:text-7xl font-bold text-gray-900">
          Hire the top talent
        </h1>
        <p class="text-lg md:text-3xl text-purple-600 mt-4">
          Explore high-paying freelance opportunities. Work with top clients and
          build your career.
        </p>
        <button
          class="mt-6 bg-purple-600 text-white py-2 px-8 rounded-full text-lg"
        >
          Hire Now
        </button>
      </div>

      <!-- Search and Filters -->
      <div
        class="flex flex-col md:flex-row items-center mt-8 space-y-4 md:space-y-0 md:space-x-4 w-full"
      >
        <div class="relative flex-grow w-full md:w-1/2 lg:w-1/3">
          <input
            type="text"
            class="w-[70%] border rounded-full py-2 px-4 pl-10 focus:outline-none focus:ring-2 focus:ring-purple-600"
            id="searchInput"
            placeholder="Search..."
          />
          <i
            class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-500"
          ></i>
        </div>
        

        <!-- Sorting Filters -->
        <div class="flex flex-wrap justify-center gap-2 w-full md:w-auto">
          <select  name="" id="" class="p-2 rounded-">
            <option value="">Select Talent</option>
            <option value="">option1</option>
          </select>
        </div>
      </div>
      <div
        class="w-full overflow-x-auto scroll-hide scroll-smooth bg-gray-100 py-5"
        id="scrollContainer"
      >
        <div class="flex flex-nowrap gap-5 px-5" id="categoryContainer"></div>
      </div>

      <!-- Categories -->
      <div class="flex flex-wrap mt-4 space-x-2" id="categoryButtons"></div>

      <!-- Job Listings -->
      <div id="jobList" class="mt-8 flex flex-col space-y-6"></div>
    </div>

    <script>
        const developers = [
            {
                avatar: "path/to/avatar1.jpg",
                name: "Rahul Srivastava",
                role: "Software Developer",
                availability: "Available Full Time",
                description: "We are looking for a skilled Full-Stack Developer to build a modern, high-performance web application.",
                certifications: ["Hackerank Certified", "AWS Certified"],
                rate_inr: 200,
                rate_usd: 2
            },
            {
                avatar: "path/to/avatar2.jpg",
                name: "Aisha Khan",
                role: "Frontend Developer",
                availability: "Available Part Time",
                description: "Experienced in building stunning UI/UX with React and Tailwind CSS.",
                certifications: ["Google UX Certified", "Frontend Masters"],
                rate_inr: 150,
                rate_usd: 1.8
            }
        ];
    
        function renderDevelopers() {
            const container = document.getElementById("developerList");
            container.innerHTML = "";
            developers.forEach(dev => {
                const devElement = document.createElement("div");
                devElement.className = "p-6 mx-auto max-w-7xl mt-2 border rounded-lg flex flex-col md:flex-row justify-between items-start md:items-center hover:bg-gray-300 ease-in smooth duration-200";
                devElement.innerHTML = `
                    <div class="flex items-center gap-4">
                        <img src="${dev.avatar}" alt="Avatar" class="w-16 h-16 rounded-full border" />
                        <div>
                            <h2 class="text-2xl font-bold">${dev.name}</h2>
                            <p class="text-gray-500">${dev.role} | ${dev.availability}</p>
                            <p class="mt-2">${dev.description} <span class="text-purple-600 cursor-pointer">Read More</span></p>
                            <div class="mt-4 flex flex-wrap gap-2">
                                ${dev.certifications.map(cert => `<span class="bg-gray-200 py-1 px-3 rounded-full">${cert}</span>`).join(" ")}
                            </div>
                        </div>
                    </div>
                    <div class="text-left md:text-right mt-4 md:mt-0">
                        <p class="text-4xl font-bold text-gray-900">₹${dev.rate_inr}/- Hr</p>
                        <p class="text-4xl font-bold text-gray-900">$${dev.rate_usd} per hour</p>
                        <p class="text-lg text-gray-500 mt-2">${dev.availability}</p>
                        <button class="mt-4 bg-purple-600 text-white py-2 px-6 rounded-full text-lg">Hire</button>
                    </div>
                `;
                container.appendChild(devElement);
            });
        }
    
        document.addEventListener("DOMContentLoaded", renderDevelopers);
    </script>
    <div id="developerList"></div>
  </body>
</html>
